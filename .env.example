# =============================================================
# Trading Bot — Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control!
# =============================================================

# Master encryption key for securing broker credentials in the database.
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_KEY=your-fernet-key-here

# -------------------------------------------------------------
# Default Bot Settings (overridable per-account in the dashboard)
# -------------------------------------------------------------
DEFAULT_TIMEFRAME=1h
POLL_INTERVAL_DIVISOR=4

# -------------------------------------------------------------
# Webhook Server (for future TradingView Pro — disabled by default)
# -------------------------------------------------------------
WEBHOOK_ENABLED=false
WEBHOOK_PORT=8080
WEBHOOK_SECRET=change-me-to-a-random-string

# -------------------------------------------------------------
# Telegram Notifications (optional — leave blank to disable)
# -------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
